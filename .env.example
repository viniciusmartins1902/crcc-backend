# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── JWT / API ─────────────────────────────────────────────────
API_KEY=sua-chave-secreta-longa-e-aleatoria

# ── Tenant CRCC ───────────────────────────────────────────────
CRCC_TENANT_ID=uuid-do-tenant-crcc

# ── Ambiente ──────────────────────────────────────────────────
APP_ENV=production

# ── Redis (opcional — sessões) ────────────────────────────────
REDIS_HOST=
REDIS_PORT=6379
